# =============================================================================
# Production Environment Variables
# =============================================================================

APP_NAME="Content AI Tool"
APP_VERSION="2.0.0"
APP_ENV=production
DEBUG=false
API_PREFIX=/api/v1

SECRET_KEY=production-secret-key-must-be-very-secure
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

DOCKER_VOLUME_PREFIX=prod
APP_PORT=8020
PGADMIN_PORT=5052

POSTGRES_USER=prod_user
POSTGRES_PASSWORD=prod_pass_secure
POSTGRES_DB=content_tool_prod_db
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
HUGGINGFACE_API_KEY=
OLLAMA_BASE_URL=

LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

FREE_TIER_MONTHLY_TOKENS=50000
PRO_TIER_MONTHLY_TOKENS=500000

ALLOWED_ORIGINS=["https://yourdomain.com", "https://app.yourdomain.com"]
