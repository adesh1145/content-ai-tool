# =============================================================================
# Development Environment Variables
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Content AI Tool"
APP_VERSION="2.0.0"
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=dev-secret-key-change-this-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Docker Run Configuration ──────────────────────────────────────────────────
DOCKER_VOLUME_PREFIX=dev
APP_PORT=8080
PGADMIN_PORT=5050

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=content_tool_dev_db
# This URL is used by the App connecting to Postgres in docker
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── LLM Provider API Keys ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GOOGLE_API_KEY=your-google-api-key
HUGGINGFACE_API_KEY=hf_your-huggingface-token
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── LLM Generation Defaults ──────────────────────────────────────────────────
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ── Usage / Quota ─────────────────────────────────────────────────────────────
FREE_TIER_MONTHLY_TOKENS=50000
PRO_TIER_MONTHLY_TOKENS=500000

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]
