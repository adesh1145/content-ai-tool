# =============================================================================
# Content AI Tool — Environment Variables
# Copy this file to .env and fill in your own values.
# NEVER commit .env to version control.
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Content AI Tool"
APP_VERSION="2.0.0"
APP_ENV=development         # development | staging | production
DEBUG=true
API_PREFIX=/api/v1

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ──────────────────────────────────────────────────────────────────
# For development (SQLite — zero setup):
DATABASE_URL=sqlite+aiosqlite:///./content_tool.db

# For production (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/content_tool_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── LLM Providers ─────────────────────────────────────────────────────────────
LLM_PROVIDER=openai          # openai | anthropic | google | huggingface | ollama

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini     # gpt-4o | gpt-4o-mini | gpt-4-turbo

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Google Gemini
GOOGLE_API_KEY=your-google-api-key
GOOGLE_MODEL=gemini-2.0-flash

# HuggingFace
HUGGINGFACE_API_KEY=hf_your-huggingface-token
HUGGINGFACE_MODEL=mistralai/Mistral-7B

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── LLM Generation Defaults ───────────────────────────────────────────────────
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ── Usage / Quota ─────────────────────────────────────────────────────────────
FREE_TIER_MONTHLY_TOKENS=50000
PRO_TIER_MONTHLY_TOKENS=500000

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]
